# =============================================================================
# Whitelist approach: ignore everything, then allow only Homework/ and Lessons/
# =============================================================================

# Ignore everything by default
/*

# Allow Homework and Lessons directories
!/Homework/
!/Lessons/

# Allow .gitignore itself
!.gitignore

# ---------- Rules within allowed directories ----------

# Ignore Python cache files
__pycache__/
*.py[cod]
*.pyo
*.pyc

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore macOS DS_Store files
.DS_Store

# Lesson and Homework Models folders
Lessons/Lesson_*/Lesson_*_Models/
Homework/Homework_*/Homework_*_Models/

# Model and data files
*.pt
*.pth
*.pkl
*.h5
*.safetensors
*.bin

# Dataset archives
*.tar.gz
*.zip
*.tar

# Temporary files
*.tmp
*.temp
*.cache

# Course_Tools cleanup timestamp
Lessons/Course_Tools/.last_cleanup

# Python build artifacts
*.egg-info/
build/
dist/

# Homework test notebooks (development only)
Homework/Homework_Tests/

# Data and workspace directories within Homework/Lessons
Homework/*/data/
Homework/*/home_workspace/
Lessons/*/data/

# Solutions notebooks (instructor only)
Solutions*.ipynb

# Resource manifests (auto-generated)
Resource_Manifest.md
